{
  "name": "agent-vault-guard-agent",
  "version": "1.0.0",
  "description": "Backend agent for AgentVault Guard - AI-powered policy enforcement for Casper",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "test:policy": "tsx scripts/test-policy.ts"
  },
  "keywords": [
