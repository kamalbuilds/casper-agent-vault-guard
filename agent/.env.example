# OpenRouter API key - obtain from https://openrouter.ai
OPENROUTER_API_KEY=sk_test_your_key_here

# OpenRouter model (default: anthropic/claude-sonnet-5)
# Other options: openai/gpt-4o, google/gemini-2.0-flash-exp, meta-llama/llama-3.1-405b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-5

# Casper contract hash (deployed contract address)
CONTRACT_HASH=hash-0123456789abcdef...

# Casper node RPC address (testnet)
CASPER_NODE_ADDRESS=https://node.testnet.cspr.cloud/rpc

# CSPR.cloud access token (for reading events)
CSPR_CLOUD_ACCESS_KEY=your_cspr_cloud_token_here

# Server port
PORT=3001

# Environment
NODE_ENV=development
